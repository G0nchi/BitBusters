rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Usuarios ===
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // === OTPs ===
    match /emailOtps/{email} {
      allow read, write: if true;
    }

    // === Proyectos ===
    match /proyectos/{proyectoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // === Comentarios ===
    match /comentarios/{comentarioId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                              request.auth.uid == resource.data.idUsuario;
    }

    // === Approvals ===
    match /approvals/{approvalId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // === Notifications ===
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // === Logs ===
    match /logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // === CHATS (corregido para permitir verificar antes de crear) ===
    match /chats/{chatId} {
      allow create: if request.auth != null &&
                      request.auth.uid in request.resource.data.participantes;

      // CLAVE: permite leer cuando el doc aun no existe (para verificar antes de crear)
      allow read: if request.auth != null &&
                    (resource == null || request.auth.uid in resource.data.participantes);

      allow update: if request.auth != null &&
                      request.auth.uid in resource.data.participantes;

      allow delete: if false;

      match /mensajes/{mensajeId} {
        allow read: if request.auth != null &&
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;

        allow create: if request.auth != null &&
                        request.auth.uid == request.resource.data.idEmisor &&
                        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;

        allow update: if request.auth != null &&
                        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;

        allow delete: if false;
      }
    }

    // === Separaciones ===
    match /separaciones/{id} {
      allow read, write: if request.auth != null;
    }

    // === Valoraciones ===
    match /valoraciones/{id} {
      allow read, write: if request.auth != null;
    }

    // === Citas ===
    match /citas/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
