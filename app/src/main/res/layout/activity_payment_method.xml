<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#F0F4F8"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/bg_circle_outline"
            android:contentDescription="Volver" />

        <TextView
            android:id="@+id/btnSaltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:text="saltar"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:padding="8dp" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- Título -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agrega tu"
                android:textSize="26sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="método de pago"
                android:textSize="26sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tu puedes editar luego tu método de pago"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp" />

            <!-- Tarjeta visual -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#2E7D32">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <!-- Chip + íconos de pago top -->
                    <LinearLayout
                        android:id="@+id/layoutTop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Chip dorado -->
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_chip_gold"
                            android:layout_marginEnd="12dp" />

                        <View android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <!-- Apple Pay / Google Pay -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Apple Pay"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/bg_pay_badge"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="G Pay"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/bg_pay_badge"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />
                    </LinearLayout>

                    <!-- Número de tarjeta -->
                    <TextView
                        android:id="@+id/tvNumeroTarjeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="**** **** **** 1234"
                        android:textSize="20sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />

                    <!-- VALID THRU + nombre + toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VALID\nTHRU"
                                android:textSize="7sp"
                                android:textColor="#A5D6A7"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:id="@+id/tvVencimiento"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="01/22"
                                android:textSize="13sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvNombreTarjeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Olivia Johns"
                                android:textSize="13sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Toggle -->
                        <Switch
                            android:id="@+id/switchTarjeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="#FFFFFF"
                            android:trackTint="#A5D6A7" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Formulario -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Nombre del titular -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <EditText
                            android:id="@+id/etNombreTitular"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toStartOf="@id/icPersona"
                            android:hint="Jonathan Anderson"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"
                            android:textColorHint="#BDBDBD"
                            android:background="@android:color/transparent"
                            android:inputType="textPersonName" />

                        <ImageView
                            android:id="@+id/icPersona"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_menu_myplaces" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#E0E0E0"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp" />

                    <!-- Número de tarjeta -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <EditText
                            android:id="@+id/etNumeroTarjeta"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toStartOf="@id/icTarjeta"
                            android:hint="1222 3443 9881 1222"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"
                            android:textColorHint="#BDBDBD"
                            android:background="@android:color/transparent"
                            android:inputType="number"
                            android:maxLength="19" />

                        <ImageView
                            android:id="@+id/icTarjeta"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_menu_agenda" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#E0E0E0"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp" />

                    <!-- Fecha vencimiento + CVV -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <!-- Fecha -->
                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp">

                            <EditText
                                android:id="@+id/etFechaVencimiento"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_toStartOf="@id/icCalendario"
                                android:hint="11/05/2023"
                                android:textSize="14sp"
                                android:textColor="#1A1A2E"
                                android:textColorHint="#BDBDBD"
                                android:background="@android:color/transparent"
                                android:inputType="number"
                                android:maxLength="10" />

                            <ImageView
                                android:id="@+id/icCalendario"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@android:drawable/ic_menu_my_calendar" />
                        </RelativeLayout>

                        <View
                            android:layout_width="0.5dp"
                            android:layout_height="match_parent"
                            android:background="#E0E0E0" />

                        <!-- CVV -->
                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp">

                            <EditText
                                android:id="@+id/etCVV"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_toStartOf="@id/icCVV"
                                android:hint="CVV"
                                android:textSize="14sp"
                                android:textColor="#1A1A2E"
                                android:textColorHint="#BDBDBD"
                                android:background="@android:color/transparent"
                                android:inputType="numberPassword"
                                android:maxLength="4" />

                            <ImageView
                                android:id="@+id/icCVV"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@android:drawable/ic_menu_agenda" />
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón Guardar -->
            <TextView
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Guardar"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:background="@drawable/bg_btn_guardar" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>