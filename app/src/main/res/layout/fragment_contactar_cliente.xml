<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/neutral_surface"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="#DDDDDD"/>

    <!-- Agent avatar + info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="36dp"
            app:cardBackgroundColor="@color/avatar_green"
            app:strokeWidth="0dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="FB"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="@font/lato_bold"
                android:gravity="center"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/agent_name"
            android:textColor="@color/neutral_dark"
            android:textSize="20sp"
            android:fontFamily="@font/lato_bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contactar_title"
            android:textColor="@color/nav_inactive"
            android:textSize="13sp"
            android:fontFamily="@font/lato_regular"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contactar_proyecto"
            android:textColor="@color/brand_lime"
            android:textSize="13sp"
            android:fontFamily="@font/lato_regular"/>

        <!-- Rating -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_star_filled" android:contentDescription="@null"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_rating"
                android:textColor="@color/neutral_dark"
                android:textSize="14sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginLeft="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/neutral_mid_1" android:layout_marginBottom="8dp"/>

    <!-- Action: Llamar -->
    <LinearLayout
        android:id="@+id/btn_llamar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp" android:layout_height="44dp"
            app:cardCornerRadius="22dp" app:cardBackgroundColor="#EAF5EC" app:strokeWidth="0dp">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                android:src="@drawable/ic_phone_call" android:padding="10dp" android:contentDescription="@null"/>
        </com.google.android.material.card.MaterialCardView>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/contactar_llamar" android:textColor="@color/neutral_dark"
                android:textSize="16sp" android:fontFamily="@font/lato_bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/contactar_llamar_sub" android:textColor="@color/nav_inactive"
                android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="›" android:textColor="@color/nav_inactive" android:textSize="20sp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/neutral_soft_1"/>

    <!-- Action: WhatsApp -->
    <LinearLayout
        android:id="@+id/btn_whatsapp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp" android:layout_height="44dp"
            app:cardCornerRadius="22dp" app:cardBackgroundColor="#E8F9EE" app:strokeWidth="0dp">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                android:src="@drawable/ic_whatsapp" android:padding="10dp" android:contentDescription="@null"/>
        </com.google.android.material.card.MaterialCardView>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/contactar_whatsapp" android:textColor="@color/neutral_dark"
                android:textSize="16sp" android:fontFamily="@font/lato_bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/contactar_whatsapp_sub" android:textColor="@color/nav_inactive"
                android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="›" android:textColor="@color/nav_inactive" android:textSize="20sp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/neutral_soft_1"/>

    <!-- Action: Correo -->
    <LinearLayout
        android:id="@+id/btn_correo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp" android:layout_height="44dp"
            app:cardCornerRadius="22dp" app:cardBackgroundColor="#EAF0F4" app:strokeWidth="0dp">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                android:src="@drawable/ic_email" android:padding="10dp" android:contentDescription="@null"/>
        </com.google.android.material.card.MaterialCardView>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/contactar_correo" android:textColor="@color/neutral_dark"
                android:textSize="16sp" android:fontFamily="@font/lato_bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/contactar_correo_sub" android:textColor="@color/nav_inactive"
                android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="›" android:textColor="@color/nav_inactive" android:textSize="20sp"/>
    </LinearLayout>
</LinearLayout>
