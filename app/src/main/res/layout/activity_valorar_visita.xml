<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/neutral_surface">

    <!-- Dark Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_deep_blue"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="8dp"
                android:contentDescription="@null"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginLeft="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_title" android:textColor="@color/white"
                    android:textSize="20sp" android:fontFamily="@font/lato_bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_subtitle" android:textColor="#AACDE0"
                    android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Client info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/neutral_soft_1"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="20dp">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardBackgroundColor="@color/avatar_teal"
                        app:strokeWidth="0dp"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="CM"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:fontFamily="@font/lato_bold"
                            android:gravity="center"/>
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Carlos Mendoza" android:textColor="@color/neutral_dark"
                        android:textSize="17sp" android:fontFamily="@font/lato_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Torres del Sol · Dpto 302 · 7 Abr, 2025"
                        android:textColor="@color/nav_inactive" android:textSize="13sp"
                        android:fontFamily="@font/lato_regular" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓ Visita realizada" android:textColor="@color/badge_confirmada_text"
                        android:textSize="13sp" android:fontFamily="@font/lato_bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stars rating -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/valorar_label_calificacion" android:textColor="@color/neutral_dark"
                android:textSize="15sp" android:fontFamily="@font/lato_bold" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/valorar_hint_calificacion" android:textColor="@color/nav_inactive"
                android:textSize="12sp" android:fontFamily="@font/lato_regular" android:layout_marginBottom="10dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:contentDescription="@null" android:layout_marginRight="4dp"/>
                <ImageView android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:contentDescription="@null" android:layout_marginRight="4dp"/>
                <ImageView android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:contentDescription="@null" android:layout_marginRight="4dp"/>
                <ImageView android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:contentDescription="@null" android:layout_marginRight="4dp"/>
                <ImageView android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_star_filled" android:alpha="0.3" android:contentDescription="@null"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Muy bueno · 4 de 5" android:textColor="@color/star_yellow"
                android:textSize="13sp" android:fontFamily="@font/lato_bold" android:layout_marginBottom="20dp"/>

            <!-- Tag chips -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/valorar_label_tags" android:textColor="@color/neutral_dark"
                android:textSize="15sp" android:fontFamily="@font/lato_bold" android:layout_marginBottom="10dp"/>

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:singleLine="false">
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_tag1" android:checked="true"
                    app:chipBackgroundColor="@color/neutral_dark" android:textColor="@color/white"
                    style="@style/Widget.Material3.Chip.Filter"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_tag2" android:checked="true"
                    app:chipBackgroundColor="@color/neutral_dark" android:textColor="@color/white"
                    style="@style/Widget.Material3.Chip.Filter"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_tag3"
                    style="@style/Widget.Material3.Chip.Filter"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_tag4" android:checked="true"
                    app:chipBackgroundColor="@color/neutral_dark" android:textColor="@color/white"
                    style="@style/Widget.Material3.Chip.Filter"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_tag5"
                    style="@style/Widget.Material3.Chip.Filter"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_tag6"
                    style="@style/Widget.Material3.Chip.Filter"/>
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/valorar_tag7"
                    style="@style/Widget.Material3.Chip.Filter"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Comentario -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/valorar_label_comentario" android:textColor="@color/neutral_dark"
                android:textSize="15sp" android:fontFamily="@font/lato_bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/valorar_hint_comentario"
                    android:minLines="4"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:fontFamily="@font/lato_regular"
                    android:text="El asesor fue muy amable y nos explicó todo con detalle. El departamento cumple con lo esperado."/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Anonymous toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/valorar_anonimo" android:textColor="@color/neutral_dark"
                        android:textSize="14sp" android:fontFamily="@font/lato_bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/valorar_anonimo_sub" android:textColor="@color/nav_inactive"
                        android:textSize="12sp" android:fontFamily="@font/lato_regular"/>
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:trackTint="@color/brand_lime"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_guardar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/valorar_btn_guardar"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/lato_bold"
                app:backgroundTint="@color/brand_lime"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
