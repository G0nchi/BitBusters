<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Ícono / Avatar del proyecto -->
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:background="@drawable/onboarding_skip_bg"
            android:backgroundTint="@color/brand_deep_blue"
            android:text="P"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp" />

        <!-- Datos del proyecto -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Nombre del proyecto -->
            <TextView
                android:id="@+id/tvNombreProyecto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del proyecto"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Distrito -->
            <TextView
                android:id="@+id/tvDistritoProyecto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Distrito"
                android:textColor="@color/neutral_dark"
                android:textSize="12sp" />

            <!-- Precio -->
            <TextView
                android:id="@+id/tvPrecioProyecto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Desde S/ 0"
                android:textColor="@color/brand_lime"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Badge de estado del proyecto -->
        <TextView
            android:id="@+id/tvEstadoProyecto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Estado"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/onboarding_skip_bg" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
