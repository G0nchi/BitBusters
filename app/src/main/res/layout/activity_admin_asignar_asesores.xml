<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/neutral_canvas">

    <!-- Fixed Header with Back Button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/brand_deep_blue">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="60dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asignar asesores"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Floating Back Button -->
        <ImageButton
            android:id="@+id/btnBackAsesores"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start|center_vertical"
            android:layout_margin="12dp"
            android:background="@drawable/circle_white_bg"
            android:contentDescription="Atrás"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:tint="@color/brand_deep_blue"
            android:elevation="4dp" />
    </FrameLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Search Bar -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBuscarAsesor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Buscar asesor..."
                    android:inputType="text"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="8dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Asesores Disponibles Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asesores disponibles"
                android:textColor="@color/brand_deep_blue"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Asesores RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAsesores"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- Action Buttons (Fixed at bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/neutral_canvas">

        <Button
            android:id="@+id/btnConfirmarAsignacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmar asignación (0)"
            android:backgroundTint="@color/brand_green"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            android:padding="14dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCancelarAsesores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/brand_deep_blue"
            android:textStyle="bold"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>

</LinearLayout>
