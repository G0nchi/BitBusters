<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/neutral_soft_1">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_deep_blue"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="8dp"
                android:tint="@color/white"
                android:contentDescription="@null"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reagendar Cita"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="@font/lato_bold"/>
                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecciona nueva fecha y hora"
                    android:textColor="#AACDE0"
                    android:textSize="12sp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card resumen de la cita actual -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/neutral_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cita actual"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cv_avatar"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="20dp"
                            app:cardBackgroundColor="@color/avatar_teal"
                            app:strokeWidth="0dp">
                            <TextView
                                android:id="@+id/tv_initials"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="CM"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:fontFamily="@font/lato_bold"
                                android:gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:id="@+id/tv_nombre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Carlos Mendoza"
                                android:textColor="@color/neutral_dark"
                                android:textSize="14sp"
                                android:fontFamily="@font/lato_bold"/>
                            <TextView
                                android:id="@+id/tv_proyecto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Torres del Sol · Dpto 302"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:fontFamily="@font/lato_regular"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:id="@+id/tv_fecha_actual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lun 7 Abr"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:fontFamily="@font/lato_bold"/>
                            <TextView
                                android:id="@+id/tv_hora_actual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10:30 AM"
                                android:textColor="@color/text_tertiary"
                                android:textSize="11sp"
                                android:fontFamily="@font/lato_regular"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Nueva fecha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nueva fecha"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/neutral_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_nav_calendar"
                        android:tint="@color/brand_deep_blue"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@null"/>
                    <EditText
                        android:id="@+id/et_fecha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="dd/mm/aaaa"
                        android:textSize="14sp"
                        android:fontFamily="@font/lato_regular"
                        android:background="@null"
                        android:inputType="date"
                        android:focusable="true"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Nueva hora -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nueva hora"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/neutral_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_nav_calendar"
                        android:tint="@color/brand_deep_blue"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@null"/>
                    <EditText
                        android:id="@+id/et_hora"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="hh:mm AM/PM"
                        android:textSize="14sp"
                        android:fontFamily="@font/lato_regular"
                        android:background="@null"
                        android:inputType="time"
                        android:focusable="true"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Motivo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivo del reagendamiento"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/neutral_surface">
                <EditText
                    android:id="@+id/et_motivo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej. Cliente solicitó cambio de horario…"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato_regular"
                    android:background="@null"
                    android:padding="14dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botón confirmar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirmar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Confirmar reagendamiento"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:fontFamily="@font/lato_bold"
                app:backgroundTint="@color/brand_lime"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
