                    android:layout_height="wrap_content"
                    android:text="HISTORIAL DE SEPARACIONES"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
