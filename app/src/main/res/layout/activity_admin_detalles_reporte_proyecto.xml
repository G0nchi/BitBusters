                                        android:textSize="11sp" />

                                </LinearLayout>

                                <com.google.android.material.chip.Chip
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Aprobada"
                                    android:textColor="@android:color/white"
