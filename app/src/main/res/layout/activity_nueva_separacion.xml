<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/neutral_soft_1">

    <!-- Dark Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_deep_blue"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="8dp"
                android:contentDescription="@null"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginLeft="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sep_title"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lato_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Torres del Sol — Dpto 302"
                    android:textColor="#AACDE0"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Step indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <!-- Step 1 active -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    app:cardCornerRadius="13dp"
                    app:cardBackgroundColor="@color/brand_lime"
                    app:strokeWidth="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="1"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="@font/lato_bold"
                        android:gravity="center"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sep_step_datos"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginLeft="6dp"
                    android:fontFamily="@font/lato_bold"/>
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="0.5"
                android:background="#4DFFFFFF"/>

            <!-- Step 2 inactive -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    app:cardCornerRadius="13dp"
                    app:cardBackgroundColor="#4DFFFFFF"
                    app:strokeWidth="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="2"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="@font/lato_bold"
                        android:gravity="center"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sep_step_pago"
                    android:textColor="#AACDE0"
                    android:textSize="13sp"
                    android:layout_marginLeft="6dp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="0.5"
                android:background="#4DFFFFFF"/>

            <!-- Step 3 inactive -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    app:cardCornerRadius="13dp"
                    app:cardBackgroundColor="#4DFFFFFF"
                    app:strokeWidth="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="@font/lato_bold"
                        android:gravity="center"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sep_step_confirmacion"
                    android:textColor="#AACDE0"
                    android:textSize="12sp"
                    android:layout_marginLeft="6dp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#EAF4FF"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sep_banner"
                    android:textColor="#1A5799"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>

            <!-- Proyecto field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sep_label_proyecto"
                android:textColor="@color/neutral_dark"
                android:textSize="14sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Torres del Sol — Miraflores"
                    android:enabled="false"
                    android:textColor="@color/neutral_dark"
                    android:fontFamily="@font/lato_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Unidad field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sep_label_unidad"
                android:textColor="@color/neutral_dark"
                android:textSize="14sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dpto 302 — Piso 3 · 78 m²"
                    android:enabled="false"
                    android:textColor="@color/neutral_dark"
                    android:fontFamily="@font/lato_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Cliente field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sep_label_cliente"
                android:textColor="@color/neutral_dark"
                android:textSize="14sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:startIconDrawable="@drawable/ic_search">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/sep_hint_cliente"
                    android:fontFamily="@font/lato_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Cliente card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/neutral_soft_1"
                app:strokeWidth="1dp"
                app:strokeColor="@color/brand_lime">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardCornerRadius="18dp"
                        app:cardBackgroundColor="@color/avatar_teal"
                        app:strokeWidth="0dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="CM"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:fontFamily="@font/lato_bold"
                            android:gravity="center"/>
                    </com.google.android.material.card.MaterialCardView>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginLeft="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Carlos Mendoza"
                            android:textColor="@color/neutral_dark"
                            android:textSize="14sp"
                            android:fontFamily="@font/lato_bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DNI 45678912 · carlos@email.com"
                            android:textColor="@color/nav_inactive"
                            android:textSize="12sp"
                            android:fontFamily="@font/lato_regular"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="@null"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Valor propuesto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sep_label_valor"
                android:textColor="@color/neutral_dark"
                android:textSize="14sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/sep_hint_valor"
                    android:inputType="numberDecimal"
                    android:fontFamily="@font/lato_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Fecha and Hora row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginRight="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sep_label_fecha"
                        android:textColor="@color/neutral_dark"
                        android:textSize="14sp"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginBottom="6dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/sep_hint_fecha"
                            android:text="04/07/2025"
                            android:fontFamily="@font/lato_regular"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginLeft="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sep_label_hora"
                        android:textColor="@color/neutral_dark"
                        android:textSize="14sp"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginBottom="6dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/sep_hint_hora"
                            android:text="10:30 AM"
                            android:fontFamily="@font/lato_regular"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Notas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sep_label_notas"
                android:textColor="@color/neutral_dark"
                android:textSize="14sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/sep_hint_notas"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:fontFamily="@font/lato_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Continuar button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_continuar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/sep_btn_continuar"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/lato_bold"
                app:backgroundTint="@color/neutral_dark"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_arrow_back"
                app:iconGravity="textEnd"
                app:iconTint="@color/white"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sep_footer"
                android:textColor="@color/nav_inactive"
                android:textSize="12sp"
                android:gravity="center"
                android:fontFamily="@font/lato_regular"
                android:layout_marginTop="8dp"
                android:paddingBottom="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
