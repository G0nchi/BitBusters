<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/neutral_soft_1">

    <!-- Dark Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_deep_blue"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="8dp"
                android:contentDescription="@null"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginLeft="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pago_title"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/lato_bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Torres del Sol — Dpto 302"
                    android:textColor="#AACDE0"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Step indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">
            <!-- Step 1 done -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    app:cardCornerRadius="13dp"
                    app:cardBackgroundColor="@color/brand_lime"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_check_circle"
                        android:padding="4dp"
                        android:contentDescription="@null"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sep_step_datos"
                    android:textColor="#AACDE0"
                    android:textSize="13sp"
                    android:layout_marginLeft="6dp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="0.5" android:background="@color/brand_lime"/>
            <!-- Step 2 active -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    app:cardCornerRadius="13dp"
                    app:cardBackgroundColor="@color/brand_lime"
                    app:strokeWidth="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="2"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="@font/lato_bold"
                        android:gravity="center"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sep_step_pago"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginLeft="6dp"
                    android:fontFamily="@font/lato_bold"/>
            </LinearLayout>
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="0.5" android:background="#4DFFFFFF"/>
            <!-- Step 3 inactive -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    app:cardCornerRadius="13dp"
                    app:cardBackgroundColor="#4DFFFFFF"
                    app:strokeWidth="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="@font/lato_bold"
                        android:gravity="center"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sep_step_confirmacion"
                    android:textColor="#AACDE0"
                    android:textSize="12sp"
                    android:layout_marginLeft="6dp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#EAF4FF"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pago_banner"
                    android:textColor="#1A5799"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato_regular"/>
            </LinearLayout>

            <!-- Resumen card (dark) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1C3D52"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pago_resumen_title"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginBottom="12dp"/>
                    <!-- Row: Proyecto -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/pago_label_proyecto"
                            android:textColor="#AACDE0" android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Torres del Sol" android:textColor="@color/white"
                            android:textSize="13sp" android:fontFamily="@font/lato_bold"/>
                    </LinearLayout>
                    <!-- Row: Unidad -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/pago_label_unidad"
                            android:textColor="#AACDE0" android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Dpto 302 - Piso 3" android:textColor="@color/white"
                            android:textSize="13sp" android:fontFamily="@font/lato_bold"/>
                    </LinearLayout>
                    <!-- Row: Cliente -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/pago_label_cliente"
                            android:textColor="#AACDE0" android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Carlos Mendoza" android:textColor="@color/white"
                            android:textSize="13sp" android:fontFamily="@font/lato_bold"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#4DFFFFFF" android:layout_marginVertical="8dp"/>
                    <!-- Row: Valor -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/pago_label_valor_inmueble"
                            android:textColor="#AACDE0" android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="S/ 320,000" android:textColor="@color/white"
                            android:textSize="13sp" android:fontFamily="@font/lato_bold"/>
                    </LinearLayout>
                    <!-- Row: Monto sep -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/pago_label_monto_sep"
                            android:textColor="#AACDE0" android:textSize="13sp" android:fontFamily="@font/lato_regular"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="S/ 3,200" android:textColor="@color/brand_lime"
                            android:textSize="14sp" android:fontFamily="@font/lato_bold"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Payment methods -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Método de pago del cliente"
                android:textColor="@color/neutral_dark"
                android:textSize="14sp"
                android:fontFamily="@font/lato_bold"
                android:layout_marginBottom="10dp"/>

            <!-- Tarjeta option -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/option_tarjeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/neutral_surface"
                app:strokeWidth="2dp"
                app:strokeColor="@color/brand_lime">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_credit_card" android:contentDescription="@null"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/pago_method_tarjeta" android:textColor="@color/neutral_dark"
                            android:textSize="14sp" android:fontFamily="@font/lato_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/pago_method_tarjeta_sub" android:textColor="@color/nav_inactive"
                            android:textSize="12sp" android:fontFamily="@font/lato_regular"/>
                    </LinearLayout>
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="true" android:buttonTint="@color/brand_lime"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Transferencia option -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/option_transferencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/neutral_surface"
                app:strokeWidth="1dp"
                app:strokeColor="@color/neutral_mid_1">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_bank" android:contentDescription="@null"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/pago_method_transferencia" android:textColor="@color/neutral_dark"
                            android:textSize="14sp" android:fontFamily="@font/lato_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/pago_method_transferencia_sub" android:textColor="@color/nav_inactive"
                            android:textSize="12sp" android:fontFamily="@font/lato_regular"/>
                    </LinearLayout>
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="false" android:buttonTint="@color/brand_lime"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Yape option -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/option_yape"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/neutral_surface"
                app:strokeWidth="1dp"
                app:strokeColor="@color/neutral_mid_1">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp"
                        android:src="@drawable/ic_qr_code" android:contentDescription="@null"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/pago_method_yape" android:textColor="@color/neutral_dark"
                            android:textSize="14sp" android:fontFamily="@font/lato_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/pago_method_yape_sub" android:textColor="@color/nav_inactive"
                            android:textSize="12sp" android:fontFamily="@font/lato_regular"/>
                    </LinearLayout>
                    <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="false" android:buttonTint="@color/brand_lime"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Monto recibido -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/pago_label_monto_recibido" android:textColor="@color/neutral_dark"
                android:textSize="14sp" android:fontFamily="@font/lato_bold" android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pago_hint_monto"
                    android:text="3200"
                    android:inputType="numberDecimal"
                    android:fontFamily="@font/lato_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- N° operación -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/pago_label_operacion" android:textColor="@color/neutral_dark"
                android:textSize="14sp" android:fontFamily="@font/lato_bold" android:layout_marginBottom="6dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pago_hint_operacion"
                    android:fontFamily="@font/lato_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirmar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/pago_btn_confirmar"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/lato_bold"
                app:backgroundTint="@color/neutral_dark"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
