<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- Mapa ocupa toda la pantalla -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Botón volver (top left) -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:layout_marginTop="48dp"
        android:src="@android:drawable/ic_menu_revert"
        android:background="@drawable/bg_circle_white_alpha"
        android:contentDescription="Volver" />

    <!-- Chips de filtro (top center) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="48dp"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/chipHospital"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="1 Hospital"
                android:textSize="12sp"
                android:textColor="#1A1A2E"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_chip_white"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipGrifos"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="2 Grifos"
                android:textSize="12sp"
                android:textColor="#1A1A2E"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_chip_white"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipColegio"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="1 Colegio"
                android:textSize="12sp"
                android:textColor="#1A1A2E"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_chip_white" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Selector de ubicación (bottom left sobre el panel) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardUbicacion"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="196dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvUbicacionActual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="La Perla, Callao"
                android:textSize="13sp"
                android:textColor="#1A1A2E"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▾"
                android:textSize="11sp"
                android:textColor="#9E9E9E" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botón centrar ubicación (bottom right sobre el panel) -->
    <ImageButton
        android:id="@+id/btnCentrar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="196dp"
        android:src="@android:drawable/ic_menu_compass"
        android:background="@drawable/bg_btn_centrar"
        android:contentDescription="Centrar mapa" />

    <!-- Panel inferior de detalles -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDetalles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalles de Ubicación"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="14dp" />

            <!-- Dirección -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:background="@drawable/bg_icon_circle_gray"
                    android:padding="8dp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvDireccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="San Domingo cuadra 15 122334,\nSan Miguel, Lima"
                    android:textSize="13sp"
                    android:textColor="#6B6B6B" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>