<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground">

    <!-- Ícono circular -->
    <com.google.android.material.card.MaterialCardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/cv_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="22dp"
        app:cardBackgroundColor="@color/badge_confirmada_bg"
        app:strokeWidth="0dp">
        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_bell"
            android:tint="@color/brand_deep_blue"
            android:contentDescription="@null"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Texto -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nueva cita confirmada"
            android:textColor="@color/neutral_dark"
            android:textSize="13sp"
            android:fontFamily="@font/lato_bold"/>

        <TextView
            android:id="@+id/tv_descripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carlos Mendoza confirmó su cita para el lunes 7 Abr."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/lato_regular"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Tiempo -->
    <TextView
        android:id="@+id/tv_tiempo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5 min"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp"
        android:fontFamily="@font/lato_regular"
        android:layout_marginStart="8dp"/>

</LinearLayout>
