<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/neutral_surface"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Franja superior de color -->
        <View
            android:id="@+id/v_stripe"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/accent_warm"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Fila: título + badge estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tv_titulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Descuento especial de lanzamiento"
                    android:textColor="@color/neutral_dark"
                    android:textSize="14sp"
                    android:fontFamily="@font/lato_bold"/>

                <TextView
                    android:id="@+id/tv_estado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Activa"
                    android:textSize="11sp"
                    android:fontFamily="@font/lato_bold"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"/>
            </LinearLayout>

            <!-- Proyecto + descuento -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_location_pin"
                    android:tint="@color/text_tertiary"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"/>

                <TextView
                    android:id="@+id/tv_proyecto"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Vista Marina Residencial"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/lato_regular"/>

                <TextView
                    android:id="@+id/tv_descuento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10% OFF"
                    android:textColor="@color/accent_warm"
                    android:textSize="16sp"
                    android:fontFamily="@font/lato_bold"/>
            </LinearLayout>

            <!-- Descripción -->
            <TextView
                android:id="@+id/tv_descripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aplica a unidades seleccionadas. Válido hasta el 30 de abril."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/lato_regular"
                android:layout_marginBottom="10dp"/>

            <!-- Vigencia -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_nav_calendar"
                    android:tint="@color/text_tertiary"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"/>

                <TextView
                    android:id="@+id/tv_vigencia"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Vigente: 01 Abr – 30 Abr 2025"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    android:fontFamily="@font/lato_regular"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_compartir"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Compartir"
                    android:textSize="12sp"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/accent_warm"
                    app:cornerRadius="8dp"
                    style="@style/Widget.Material3.Button"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
