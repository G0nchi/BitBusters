<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_canvas"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/onboardingCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/onboarding_card_bg"
        android:clipToOutline="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="52dp"
                android:layout_height="55dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="30dp"
                android:contentDescription="@string/logo_content_description"
                android:src="@drawable/onboarding_logo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="ImageContrastCheck" />

            <TextView
                android:id="@+id/skipButton"
                android:layout_width="86dp"
                android:layout_height="38dp"
                android:layout_marginTop="37dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/onboarding_skip_bg"
                android:gravity="center"
                android:text="@string/onboarding_skip"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/titleLine1"
                style="@style/TextAppearance.BitBusters.DisplayTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="124dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="@string/onboarding_title_line_1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/titleLine2"
                style="@style/TextAppearance.BitBusters.DisplayTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="@string/onboarding_title_line_2_a"
                android:textColor="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/titleLine1" />

            <TextView
                android:id="@+id/body"
                style="@style/TextAppearance.BitBusters.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="@string/onboarding_body"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/titleLine2" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/heroCard"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/body">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/heroImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:src="@drawable/onboarding_hero" />

                    <HorizontalScrollView
                        android:id="@+id/chipsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="64dp"
                        android:fillViewport="false"
                        android:overScrollMode="never"
                        android:paddingStart="50dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/chipAll"
                                style="@style/Widget.BitBusters.ChipActive"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/onboarding_chip_all"
                                android:textAppearance="@style/TextAppearance.BitBusters.ChipActive" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/chipType1"
                                style="@style/Widget.BitBusters.ChipInactive"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/onboarding_chip_type_1"
                                android:textAppearance="@style/TextAppearance.BitBusters.ChipInactive" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/chipType2"
                                style="@style/Widget.BitBusters.ChipInactive"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/onboarding_chip_type_2"
                                android:textAppearance="@style/TextAppearance.BitBusters.ChipInactive" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/chipType3"
                                style="@style/Widget.BitBusters.ChipInactive"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="24dp"
                                android:text="@string/onboarding_chip_type_3"
                                android:textAppearance="@style/TextAppearance.BitBusters.ChipInactive" />

                        </LinearLayout>
                    </HorizontalScrollView>

                    <LinearLayout
                        android:id="@+id/progressBar"
                        android:layout_width="70dp"
                        android:layout_height="3dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="103dp"
                        android:background="@drawable/onboarding_progress_track"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="47dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/onboarding_progress_fill" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/nextButton"
                        style="@style/Widget.BitBusters.PrimaryButton"
                        android:layout_width="190dp"
                        android:layout_height="54dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="38dp"
                        android:text="@string/onboarding_next" />

                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>