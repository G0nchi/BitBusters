<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_canvas"
    tools:context=".activities.superadmin.SuperadminLogsActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="214dp"
            android:background="@drawable/sa_top_header_bg"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sa_logs_title"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/logsFiltersButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/sa_search_bg">
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_filter_16"
                        android:tint="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="@string/sa_logs_filters_button"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/sa_search_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_search_16"
                    android:tint="@color/overlay_white_30" />

                <EditText
                    android:id="@+id/searchLogsInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/sa_logs_search_hint"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/white"
                    android:textColorHint="@color/overlay_white_30"
                    android:textSize="13sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="39dp"
                android:layout_marginTop="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/filterAllLogsChip"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:background="@drawable/sa_filter_chip_selected_bg"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/sa_filter_all"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filterReservationsLogsChip"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/sa_filter_chip_unselected_bg"
                        android:gravity="center"
                        android:minWidth="84dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/sa_logs_filter_reservations"
                        android:textColor="@color/overlay_white_30"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filterPaymentsLogsChip"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/sa_filter_chip_unselected_bg"
                        android:gravity="center"
                        android:minWidth="110dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/sa_logs_filter_payments"
                        android:textColor="@color/overlay_white_30"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filterAppointmentsLogsChip"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/sa_filter_chip_unselected_bg"
                        android:gravity="center"
                        android:minWidth="108dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/sa_logs_filter_appointments"
                        android:textColor="@color/overlay_white_30"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/filterEnablementsLogsChip"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/sa_filter_chip_unselected_bg"
                        android:gravity="center"
                        android:minWidth="132dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/sa_logs_filter_enablements"
                        android:textColor="@color/overlay_white_30"
                        android:textSize="12sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/logsActiveTagText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/sa_logs_active_tag_default"
                android:textColor="@color/overlay_white_30"
                android:textSize="11sp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="194dp"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="90dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/logsCountText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sa_logs_count_default"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_medium"
                    android:textSize="11sp" />

                <LinearLayout
                    android:id="@+id/logsListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@color/white"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home_20"
                    android:tint="@color/text_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sa_nav_home"
                    android:textColor="@color/text_medium"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navUsers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_users_20"
                    android:tint="@color/text_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sa_nav_users"
                    android:textColor="@color/text_medium"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navApprovals"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_approvals_20"
                    android:tint="@color/text_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sa_nav_approvals"
                    android:textColor="@color/text_medium"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navReports"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_reports_20"
                    android:tint="@color/text_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sa_nav_reports"
                    android:textColor="@color/text_medium"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navLogs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_logs_20"
                    android:tint="@color/brand_lime" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sa_nav_logs"
                    android:textColor="@color/brand_lime"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
