<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_canvas"
    tools:context=".activities.access.RegisterAccountActivity">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/onboarding_card_bg"
        android:clipToOutline="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <!-- Botón atrás -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/backButton"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:contentDescription="@string/back_button_content_description"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text=""
                    app:backgroundTint="@color/neutral_soft_1"
                    app:cornerRadius="25dp"
                    app:icon="@drawable/ic_chevron_left"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@null" />

                <!-- Título -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/register_account_title_base"
                        android:textColor="@color/neutral_dark"
                        android:textSize="25sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/register_account_title_accent"
                        android:textColor="@color/brand_blue"
                        android:textSize="25sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Subtítulo -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="24dp"
                    android:text="@string/register_subtitle_join"
                    android:textColor="@color/text_medium"
                    android:textSize="12sp" />

                <!-- Formulario -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="24dp"
                    android:orientation="vertical">

                    <!-- Nombre completo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:background="@drawable/auth_input_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_person_20" />

                        <EditText
                            android:id="@+id/fullNameInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="@string/register_full_name_hint"
                            android:inputType="textPersonName|textCapWords"
                            android:textColor="@color/neutral_dark"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Email -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/auth_input_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_email_20" />

                        <EditText
                            android:id="@+id/emailInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="@string/register_email_hint"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/neutral_dark"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Teléfono -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/auth_input_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_phone_20" />

                        <EditText
                            android:id="@+id/phoneInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="@string/register_phone_hint"
                            android:inputType="phone"
                            android:maxLength="9"
                            android:textColor="@color/neutral_dark"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- DNI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/auth_input_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_badge_20" />

                        <EditText
                            android:id="@+id/dniInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="@string/register_dni_hint"
                            android:inputType="number"
                            android:maxLength="8"
                            android:textColor="@color/neutral_dark"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Contraseña -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/auth_input_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_lock_20" />

                        <EditText
                            android:id="@+id/passwordInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="@string/register_password_hint"
                            android:inputType="textPassword"
                            android:textColor="@color/neutral_dark"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Confirmar contraseña -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/auth_input_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_lock_20" />

                        <EditText
                            android:id="@+id/repeatPasswordInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="@string/register_password_repeat_hint"
                            android:inputType="textPassword"
                            android:textColor="@color/neutral_dark"
                            android:textColorHint="@color/text_placeholder"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ProgressBar circular -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:indeterminateTint="@color/brand_blue"
                    android:visibility="gone" />

                <!-- Botón Registrarme -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/registerButton"
                    style="@style/Widget.BitBusters.PrimaryButton"
                    android:layout_width="278dp"
                    android:layout_height="63dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:text="@string/register_submit" />

                <!-- Link "¿Ya tienes cuenta? Inicia sesión" -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/register_already_account"
                        android:textColor="@color/text_medium"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/loginLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/register_login_link"
                        android:textColor="@color/brand_blue"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
