<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_canvas"
    tools:context=".activities.superadmin.SuperadminUsersActivity">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="196dp"
                android:background="@drawable/sa_top_header_bg"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/sa_users_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/sa_search_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_search_16"
                        android:tint="@color/overlay_white_30" />

                    <EditText
                        android:id="@+id/searchUsersInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/sa_search_hint"
                        android:textColor="@color/white"
                        android:textColorHint="@color/overlay_white_30"
                        android:textSize="14sp" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="39dp"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/usersStatusFilters"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/filterAllChip"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:background="@drawable/sa_filter_chip_selected_bg"
                            android:gravity="center"
                            android:minWidth="72dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="@string/sa_filter_all"
                            android:textColor="@color/white"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/filterActiveChip"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/sa_filter_chip_unselected_bg"
                            android:gravity="center"
                            android:minWidth="74dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="@string/sa_status_active"
                            android:textColor="@color/overlay_white_30"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/filterInactiveChip"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/sa_filter_chip_unselected_bg"
                            android:gravity="center"
                            android:minWidth="84dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="@string/sa_status_inactive"
                            android:textColor="@color/overlay_white_30"
                            android:textSize="12sp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@color/white"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/tabAdmins"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tabAdminsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sa_tab_admins"
                        android:textColor="@color/brand_deep_blue"
                        android:textSize="14sp" />

                    <View
                        android:id="@+id/tabAdminsLine"
                        android:layout_width="90dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/sa_tab_active_line" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabAdvisors"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tabAdvisorsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sa_tab_advisors"
                        android:textColor="@color/text_medium"
                        android:textSize="14sp" />

                    <View
                        android:id="@+id/tabAdvisorsLine"
                        android:layout_width="90dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/sa_tab_active_line"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabClients"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tabClientsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sa_tab_clients"
                        android:textColor="@color/text_medium"
                        android:textSize="14sp" />

                    <View
                        android:id="@+id/tabClientsLine"
                        android:layout_width="90dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/sa_tab_active_line"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <ScrollView
                android:id="@+id/usersScrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/usersListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/sa_bottom_nav_bg"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/navHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_home_20"
                        android:tint="@color/text_medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sa_nav_home"
                        android:textColor="@color/text_medium"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navUsers"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_users_20"
                        android:tint="@color/brand_lime" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sa_nav_users"
                        android:textColor="@color/brand_lime"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navApprovals"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_approvals_20"
                        android:tint="@color/text_medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sa_nav_approvals"
                        android:textColor="@color/text_medium"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navReports"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_reports_20"
                        android:tint="@color/text_medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sa_nav_reports"
                        android:textColor="@color/text_medium"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navLogs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_logs_20"
                        android:tint="@color/text_medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sa_nav_logs"
                        android:textColor="@color/text_medium"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
