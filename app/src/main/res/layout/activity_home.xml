                                    android:text=" Jakarta"
                                    android:textSize="11sp"
                                    android:textColor="#9E9E9E" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

        </LinearLayout>
