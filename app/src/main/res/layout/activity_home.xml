<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- Contenido principal con scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header azul degradado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A2E44"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="32dp">

                <!-- Top row: ubicación + íconos -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp">

                    <!-- Ubicación -->
                    <LinearLayout
                        android:id="@+id/layoutUbicacion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvUbicacion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lima, Perú"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginStart="4dp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" ▾"
                            android:textSize="12sp"
                            android:textColor="#B0BEC5" />
                    </LinearLayout>

                    <!-- Íconos derecha: notificación + avatar -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/btnNotificaciones"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@android:drawable/ic_dialog_info"
                            android:background="@drawable/bg_circle_white_alpha"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Notificaciones" />

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/imgPerfil"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@android:drawable/ic_menu_myplaces" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- Saludo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Hola, Jonathan!"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Encuentra tu próximo hogar"
                    android:textSize="16sp"
                    android:textColor="#B0BEC5"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="16dp" />

                <!-- Filtros: Todos / Tipo 1 / Tipo 2 / Tipo 3 -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnTodos"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Todos"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:background="@drawable/bg_filter_selected"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/btnTipo1"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Tipo 1"
                            android:textSize="13sp"
                            android:textColor="#B0BEC5"
                            android:gravity="center"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:background="@drawable/bg_filter_unselected"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/btnTipo2"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Tipo 2"
                            android:textSize="13sp"
                            android:textColor="#B0BEC5"
                            android:gravity="center"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:background="@drawable/bg_filter_unselected"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/btnTipo3"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Tipo 3"
                            android:textSize="13sp"
                            android:textColor="#B0BEC5"
                            android:gravity="center"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:background="@drawable/bg_filter_unselected" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Barra de búsqueda -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="-20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:id="@+id/icSearch"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true"
                        android:src="@android:drawable/ic_menu_search" />

                    <EditText
                        android:id="@+id/etBuscar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toEndOf="@id/icSearch"
                        android:layout_toStartOf="@id/icMic"
                        android:hint="Buscar por distrito..."
                        android:textSize="13sp"
                        android:textColorHint="#BDBDBD"
                        android:background="@android:color/transparent"
                        android:paddingStart="8dp"
                        android:inputType="text" />

                    <ImageView
                        android:id="@+id/icMic"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:src="@android:drawable/ic_btn_speak_now" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sección Destacados -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Destacados"
                    android:textSize="16sp"
                    android:textColor="#1A1A2E"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvVerTodos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="ver todos"
                    android:textSize="13sp"
                    android:textColor="#1A7EBD" />
            </RelativeLayout>

            <!-- Scroll horizontal de destacados -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Card destacada 1 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardDestacado1"
                        android:layout_width="200dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:scaleType="centerCrop" />

                            <!-- Badge tipo -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="8dp"
                                android:text="Apartment"
                                android:textSize="10sp"
                                android:textColor="#FFFFFF"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:background="@drawable/bg_badge_dark" />

                            <!-- Corazón favorito -->
                            <ImageButton
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="8dp"
                                android:src="@android:drawable/btn_star_big_on"
                                android:background="@android:color/transparent"
                                android:contentDescription="Favorito" />

                            <!-- Info abajo -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_alignParentBottom="true"
                                android:orientation="vertical"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Catalina Ventor"
                                    android:textSize="13sp"
                                    android:textColor="#1A1A2E"
                                    android:fontFamily="sans-serif-medium" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="★ 4.9"
                                        android:textSize="11sp"
                                        android:textColor="#FFC107" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="  📍 Santa Catalina, Lima"
                                        android:textSize="10sp"
                                        android:textColor="#9E9E9E" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="S/ 280,000"
                                    android:textSize="13sp"
                                    android:textColor="#1A1A2E"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Card destacada 2 (Villa) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardDestacado2"
                        android:layout_width="200dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:scaleType="centerCrop" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="8dp"
                                android:text="Villa"
                                android:textSize="10sp"
                                android:textColor="#FFFFFF"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:background="@drawable/bg_badge_dark" />

                            <ImageButton
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="8dp"
                                android:src="@android:drawable/btn_star_big_on"
                                android:background="@android:color/transparent"
                                android:contentDescription="Favorito" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_alignParentBottom="true"
                                android:orientation="vertical"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Residencial Park"
                                    android:textSize="13sp"
                                    android:textColor="#1A1A2E"
                                    android:fontFamily="sans-serif-medium" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="★ 4.8"
                                        android:textSize="11sp"
                                        android:textColor="#FFC107" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="  📍 Miraflores, Lima"
                                        android:textSize="10sp"
                                        android:textColor="#9E9E9E" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="S/ 320,000"
                                    android:textSize="13sp"
                                    android:textColor="#1A1A2E"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Sección Proyectos Guardados -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proyectos Guardados"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <!-- Grid 2 columnas de proyectos guardados -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:useDefaultMargins="false">

                <!-- Proyecto 1: Torre Miramar -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTorreMiramar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="120dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:scaleType="centerCrop" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_margin="8dp"
                                android:text="S/ 195,000"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:background="@drawable/bg_badge_dark" />

                            <ImageButton
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:src="@android:drawable/btn_star_big_on"
                                android:background="@android:color/transparent"
                                android:contentDescription="Guardado" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Torre Miramar"
                                android:textSize="13sp"
                                android:textColor="#1A1A2E"
                                android:fontFamily="sans-serif-medium" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="2dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="★ 4.9"
                                    android:textSize="11sp"
                                    android:textColor="#FFC107" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" Miraflores"
                                    android:textSize="11sp"
                                    android:textColor="#9E9E9E" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Proyecto 2: Residencial El Park -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardResidencialPark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="120dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:scaleType="centerCrop" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_margin="8dp"
                                android:text="S/ 248,000"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:background="@drawable/bg_badge_dark" />

                            <ImageButton
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:src="@android:drawable/btn_star_big_on"
                                android:background="@android:color/transparent"
                                android:contentDescription="Guardado" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Residencial El Park"
                                android:textSize="13sp"
                                android:textColor="#1A1A2E"
                                android:fontFamily="sans-serif-medium" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="2dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="★ 4.8"
                                    android:textSize="11sp"
                                    android:textColor="#FFC107" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" San Miguel"
                                    android:textSize="11sp"
                                    android:textColor="#9E9E9E" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Proyecto 3: Condominio Las Lomas -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCondominioLomas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="120dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:scaleType="centerCrop" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_margin="8dp"
                                android:text="S/ 220,000"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:background="@drawable/bg_badge_dark" />

                            <ImageButton
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:src="@android:drawable/btn_star_big_off"
                                android:background="@android:color/transparent"
                                android:contentDescription="Guardado" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Condominio Las Lomas"
                                android:textSize="13sp"
                                android:textColor="#1A1A2E"
                                android:fontFamily="sans-serif-medium" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="2dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="★ 4.7"
                                    android:textSize="11sp"
                                    android:textColor="#FFC107" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" Jakarta"
                                    android:textSize="11sp"
                                    android:textColor="#9E9E9E" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Proyecto 4: Catalina Sky -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCatalinaSky"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="120dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
