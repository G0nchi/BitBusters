<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="bottom"
    android:paddingBottom="4dp">

    <!-- Avatar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="32dp"
        android:layout_height="32dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/avatar_teal"
        app:strokeWidth="0dp"
        android:layout_marginRight="8dp">
        <TextView
            android:id="@+id/tv_initials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="CM"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:fontFamily="@font/lato_bold"
            android:gravity="center"/>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="0"
        android:orientation="vertical"
        android:maxWidth="260dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/bubble_received"
            app:strokeWidth="0dp"
            app:cardElevation="1dp">
            <TextView
                android:id="@+id/tv_mensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buenos días Juan, quería confirmar si la cita del lunes sigue en pie."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="@font/lato_regular"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:maxWidth="240dp"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_hora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9:45 AM"
            android:textColor="@color/nav_inactive"
            android:textSize="11sp"
            android:fontFamily="@font/lato_regular"
            android:layout_marginTop="2dp"
            android:layout_marginLeft="4dp"/>
    </LinearLayout>

    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
</LinearLayout>
