<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero imagen con overlay -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">

                <ImageView
                    android:id="@+id/imgHero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/proyecto_catalina_ventor"
                    android:scaleType="centerCrop" />

                <!-- Botón volver -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_margin="12dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="@drawable/bg_circle_white_alpha"
                    android:contentDescription="Volver" />

                <!-- Botones top derecha: compartir + favorito -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnCompartir"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:src="@android:drawable/ic_menu_share"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:contentDescription="Compartir" />

                    <ImageButton
                        android:id="@+id/btnFavorito"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/btn_star_big_on"
                        android:background="@drawable/bg_circle_green"
                        android:contentDescription="Favorito" />
                </LinearLayout>

                <!-- Rating badge inferior izquierda -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="12dp"
                    android:text="★ 4.9"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_badge_dark" />

                <!-- Badge tipo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="72dp"
                    android:layout_marginBottom="12dp"
                    android:text="Apartamento"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_badge_dark" />

                <!-- Miniaturas galería inferior derecha -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginBottom="4dp"
                        android:src="@drawable/proyecto_catalina_sky"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_rounded_8" />

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/proyecto_torre_miramar"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_rounded_8" />

                    <!-- Badge +3 -->
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:text="+3"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:background="@drawable/bg_badge_dark" />
                </LinearLayout>
            </FrameLayout>

            <!-- Contenido principal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F0F4F8"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Nombre + precio -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNombreProyecto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Torres Unidas"
                            android:textSize="20sp"
                            android:textColor="#1A1A2E"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📍"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvUbicacion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="La Peral, Callao"
                                android:textSize="12sp"
                                android:textColor="#9E9E9E"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvPrecio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/ 220"
                            android:textSize="20sp"
                            android:textColor="#1A1A2E"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="por mes"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- Botones Rentar / Comprar / Agendar + QR -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/btnRentar"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Rentar"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:paddingStart="22dp"
                            android:paddingEnd="22dp"
                            android:background="@drawable/bg_btn_rentar"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/btnComprar"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Comprar"
                            android:textSize="13sp"
                            android:textColor="#1A1A2E"
                            android:gravity="center"
                            android:paddingStart="22dp"
                            android:paddingEnd="22dp"
                            android:background="@drawable/bg_btn_comprar"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/btnAgendarCita"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Agendar Cita"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="@drawable/bg_btn_guardar"
                            android:layout_marginEnd="10dp" />

                        <ImageButton
                            android:id="@+id/btnQR"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@android:drawable/ic_menu_zoom"
                            android:background="@drawable/bg_circle_outline"
                            android:contentDescription="Ver QR"
                            android:layout_marginEnd="8dp" />

                        <ImageButton
                            android:id="@+id/btnCompartirProyecto"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@android:drawable/ic_menu_share"
                            android:background="@drawable/bg_circle_outline"
                            android:contentDescription="Compartir proyecto" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Card Asesor -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAsesor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/imgAsesor"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/avatar_asesor_fabri" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/imgAsesor"
                            android:layout_centerVertical="true"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <TextView
                                android:id="@+id/tvNombreAsesor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fabri"
                                android:textSize="14sp"
                                android:textColor="#1A1A2E"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Asesor"
                                android:textSize="12sp"
                                android:textColor="#9E9E9E" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnChatAsesor"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_dialog_email"
                            android:background="@drawable/bg_circle_outline"
                            android:contentDescription="Chat con asesor" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Chips: Cuartos / Baño / Dorm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="🛏 2 Cuartos"
                        android:textSize="12sp"
                        android:textColor="#1A1A2E"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/bg_chip"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="🚿 1 Baño"
                        android:textSize="12sp"
                        android:textColor="#1A1A2E"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/bg_chip"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="🚪 2 Dor"
                        android:textSize="12sp"
                        android:textColor="#1A1A2E"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:background="@drawable/bg_chip" />
                </LinearLayout>

                <!-- Sección Ubicación e instalaciones -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ubicación e instalaciones públicas"
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp" />

                <!-- Dirección -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="San Domingo cuando No 123256,\nSan Miguel, Lima"
                        android:textSize="13sp"
                        android:textColor="#6B6B6B" />
                </LinearLayout>

                <!-- Distancia -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔵"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.5km desde tu ubicación"
                        android:textSize="13sp"
                        android:textColor="#6B6B6B" />
                </LinearLayout>

                <!-- Chips de lugares de interés -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="🏥 Hospitales"
                            android:textSize="12sp"
                            android:textColor="#1A1A2E"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_chip"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="⛳ Golfas"
                            android:textSize="12sp"
                            android:textColor="#1A1A2E"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_chip"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="🎓 Colegio"
                            android:textSize="12sp"
                            android:textColor="#1A1A2E"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/bg_chip" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Mapa placeholder -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMapa"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- En Lab 6 reemplazar con fragment del mapa -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_menu_mapmode"
                            android:scaleType="centerCrop"
                            android:background="#D0E8D0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:text="Mira todo el mapa"
                            android:textSize="12sp"
                            android:textColor="#1A7EBD"
                            android:background="@drawable/bg_date_pill"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <!-- Coste de vida -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coste de vida"
                        android:textSize="15sp"
                        android:textColor="#1A1A2E"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvVerCostos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="ver variadas"
                        android:textSize="12sp"
                        android:textColor="#1A7EBD" />
                </RelativeLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S/ 830/mes"
                            android:textSize="16sp"
                            android:textColor="#1A1A2E"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sin datos acerca de los alquileres en esta ubicación"
                            android:textSize="12sp"
                            android:textColor="#9E9E9E"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Comentarios -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comentarios"
                        android:textSize="15sp"
                        android:textColor="#1A1A2E"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvVerTodosComentarios"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="ver todos"
                        android:textSize="12sp"
                        android:textColor="#1A7EBD" />
                </RelativeLayout>

                <!-- Card rating global -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A2E44">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textSize="28sp"
                            android:textColor="#FFC107"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★★★★★  4.9"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Comentario 1: Kurt Mulins -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/imgKurt"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_alignParentStart="true"
                                android:src="@drawable/avatar_milano" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/imgKurt"
                                android:layout_centerVertical="true"
                                android:orientation="vertical"
                                android:paddingStart="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Kurt Mulins"
                                    android:textSize="13sp"
                                    android:textColor="#1A1A2E"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="★★★★★"
                                android:textSize="12sp"
                                android:textColor="#FFC107" />
                        </RelativeLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fue un poco malo todo pero tulla típica del establecimiento. No aceptar personas/fn"
                            android:textSize="12sp"
                            android:textColor="#6B6B6B"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Comentario 2: Ray Stevenson -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/imgRay"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_alignParentStart="true"
                                android:src="@drawable/avatar_samuel" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/imgRay"
                                android:layout_centerVertical="true"
                                android:orientation="vertical"
                                android:paddingStart="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ray Stevenson"
                                    android:textSize="13sp"
                                    android:textColor="#1A1A2E"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="★★★★"
                                android:textSize="12sp"
                                android:textColor="#FFC107" />
                        </RelativeLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fue un poco más viral. todo bien yo también tengo una duda si lo recomiendo relativo"
                            android:textSize="12sp"
                            android:textColor="#6B6B6B"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Botón agregar comentario -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/btnAgregarComentario"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="+"
                        android:textSize="22sp"
                        android:textColor="#1A1A2E"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_outline" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agregar Comentario"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom bar: Separar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/btnSeparar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Separar Inmueble"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:background="@drawable/bg_btn_rentar" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>