<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/bg_circle_outline"
            android:contentDescription="Volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Agenda tu cita"
            android:textSize="16sp"
            android:textColor="#1A1A2E"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="100dp">

            <!-- Card del proyecto -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/imgProyecto"
                        android:layout_width="110dp"
                        android:layout_height="match_parent"
                        android:src="@drawable/proyecto_catalina_ventor"
                        android:scaleType="centerCrop" />

                    <!-- Badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignStart="@id/imgProyecto"
                        android:layout_alignBottom="@id/imgProyecto"
                        android:layout_margin="8dp"
                        android:text="Apartment"
                        android:textSize="9sp"
                        android:textColor="#FFFFFF"
                        android:paddingStart="5dp"
                        android:paddingEnd="5dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:background="@drawable/bg_badge_dark" />

                    <!-- Corazón -->
                    <ImageButton
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignStart="@id/imgProyecto"
                        android:layout_alignParentTop="true"
                        android:layout_margin="8dp"
                        android:src="@android:drawable/btn_star_big_off"
                        android:background="@android:color/transparent"
                        android:contentDescription="Favorito" />

                    <!-- Info derecha -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgProyecto"
                        android:layout_centerVertical="true"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:id="@+id/tvNombreProyecto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Los Robles"
                            android:textSize="15sp"
                            android:textColor="#1A1A2E"
                            android:fontFamily="sans-serif-medium" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="3dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📍"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" La Perla, Callao"
                                android:textSize="11sp"
                                android:textColor="#9E9E9E" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Asesor Asignado: Juan Perez"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:layout_marginTop="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Renta"
                            android:textSize="11sp"
                            android:textColor="#1A7EBD"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:background="@drawable/bg_badge_completada"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Selecciona una fecha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona una fecha"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- Campo fecha (abre CalendarDialog) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFecha"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvFechaSeleccionada"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agenda tu cita"
                        android:textSize="13sp"
                        android:textColor="#BDBDBD" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Selecciona la hora -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona la hora"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <!-- Fila 1 de horarios -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/hora900"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="9:00AM"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:background="@drawable/bg_hora_normal" />

                <TextView
                    android:id="@+id/hora1000"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="10:00AM"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:background="@drawable/bg_hora_normal" />

                <TextView
                    android:id="@+id/hora1100"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="11:00AM"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:background="@drawable/bg_hora_normal" />

                <TextView
                    android:id="@+id/hora1200"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="12:00AM"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:background="@drawable/bg_hora_normal" />
            </LinearLayout>

            <!-- Fila 2 de horarios -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/hora200"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="2:00 PM"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:background="@drawable/bg_hora_normal" />

                <TextView
                    android:id="@+id/hora400"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="4:00 PM"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:background="@drawable/bg_hora_normal" />

                <!-- Espacios vacíos para alinear -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- Nota al asesor -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escribe una nota a tu asesor de Venta"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="top">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etNota"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Escribe aquí tu mensaje"
                        android:textSize="13sp"
                        android:textColorHint="#BDBDBD"
                        android:textColor="#1A1A2E"
                        android:background="@android:color/transparent"
                        android:inputType="textMultiLine"
                        android:maxLines="3"
                        android:gravity="top" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Método de Pago -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Método de Pago"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Tarjeta 1 (seleccionada - verde) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardTarjeta1"
                        android:layout_width="150dp"
                        android:layout_height="90dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#2E7D32">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentStart="true"
                                android:layout_alignParentTop="true"
                                android:src="@android:drawable/checkbox_on_background"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerHorizontal="true"
                                android:layout_centerVertical="true"
                                android:text="•••••• 1222"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_alignParentBottom="true"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Balance"
                                        android:textSize="9sp"
                                        android:textColor="#A5D6A7" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="$ 31,250"
                                        android:textSize="12sp"
                                        android:textColor="#FFFFFF"
                                        android:fontFamily="sans-serif-medium" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⏻"
                                    android:textSize="16sp"
                                    android:textColor="#FFFFFF" />
                            </LinearLayout>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Tarjeta 2 (seleccionada - azul) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardTarjeta2"
                        android:layout_width="150dp"
                        android:layout_height="90dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1A2E44">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentStart="true"
                                android:layout_alignParentTop="true"
                                android:src="@android:drawable/checkbox_on_background"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerHorizontal="true"
                                android:layout_centerVertical="true"
                                android:text="•••••• 1542"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_alignParentBottom="true"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Balance"
                                        android:textSize="9sp"
                                        android:textColor="#90A4AE" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="$ 54,200"
                                        android:textSize="12sp"
                                        android:textColor="#FFFFFF"
                                        android:fontFamily="sans-serif-medium" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="VISA"
                                    android:textSize="12sp"
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom: Next -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_toStartOf="@id/btnNextArrow"
            android:layout_marginEnd="12dp"
            android:text="Next"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:background="@drawable/bg_btn_guardar" />

        <ImageButton
            android:id="@+id/btnNextArrow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/ic_media_next"
            android:background="@drawable/bg_btn_guardar"
            android:tint="#FFFFFF"
            android:contentDescription="Siguiente" />
    </RelativeLayout>

</LinearLayout>