<?xml version="1.0" encoding="utf-8"?>
<!--
    Root: vertical para poder añadir la fila "finalizado" bajo el contenido.
    El clickable/focusable sigue en el root para abrir la conversación.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Fila principal: avatar + info + hora/badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInitials"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardCornerRadius="25dp"
            app:strokeWidth="0dp">
            <TextView
                android:id="@+id/tvInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="CM"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/lato_bold"
                android:gravity="center"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginLeft="12dp">

            <TextView
                android:id="@+id/tvChatName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textColor="@color/neutral_dark"
                android:textSize="15sp"
                android:fontFamily="@font/lato_bold"/>

            <TextView
                android:id="@+id/tvChatProyecto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Torres del Sol · Dpto 302"
                android:textColor="@color/brand_deep_blue"
                android:textSize="11sp"
                android:fontFamily="@font/lato_bold"
                android:drawableStart="@drawable/ic_nav_home"
                android:drawablePadding="4dp"
                android:drawableTint="@color/brand_deep_blue"
                android:visibility="gone"
                android:layout_marginTop="1dp"
                android:layout_marginBottom="1dp"/>

            <TextView
                android:id="@+id/tvLastMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Último mensaje..."
                android:textColor="@color/nav_inactive"
                android:textSize="13sp"
                android:fontFamily="@font/lato_regular"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end|center_vertical">

            <TextView
                android:id="@+id/tvChatTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:32"
                android:textColor="@color/nav_inactive"
                android:textSize="12sp"
                android:fontFamily="@font/lato_regular"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUnread"
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:cardCornerRadius="11dp"
                app:cardBackgroundColor="@color/brand_lime"
                app:strokeWidth="0dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/tvUnreadCount"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="2"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:fontFamily="@font/lato_bold"
                    android:gravity="center"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Fila "Conversación finalizada" — visible solo en chats no recientes -->
    <LinearLayout
        android:id="@+id/ll_finalizado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="62dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_alert_16"
            android:tint="@color/nav_inactive"
            android:contentDescription="@null"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Conversación finalizada"
            android:textColor="@color/nav_inactive"
            android:textSize="11sp"
            android:fontFamily="@font/lato_regular"
            android:layout_marginLeft="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reconectar"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Reconectar"
            android:textSize="11sp"
            android:textColor="@color/brand_deep_blue"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="@color/brand_deep_blue"
            app:strokeWidth="1dp"
            app:cornerRadius="20dp"/>
    </LinearLayout>

</LinearLayout>
