<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end|bottom"
    android:paddingBottom="4dp">

    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/bubble_sent"
            app:strokeWidth="0dp"
            app:cardElevation="1dp">
            <TextView
                android:id="@+id/tv_mensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Buenos días Carlos! Sí, todo confirmado para el lunes 7 a las 10:30 AM."
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/lato_regular"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:maxWidth="240dp"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="end" android:layout_marginTop="2dp"
            android:layout_marginRight="4dp">
            <TextView
                android:id="@+id/tv_hora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9:48 AM"
                android:textColor="@color/nav_inactive"
                android:textSize="11sp"
                android:fontFamily="@font/lato_regular"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=" ✓" android:textColor="@color/nav_inactive" android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
