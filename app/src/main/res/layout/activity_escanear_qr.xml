<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Vista de cámara ZXing -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Barra superior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/overlay_dark_transparent">

        <ImageButton
            android:id="@+id/btnCancelar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancelar" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Escanear QR"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/lato_family"
            android:layout_marginStart="8dp" />

        <!-- Botón linterna -->
        <ImageButton
            android:id="@+id/btnLinterna"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_torch"
            android:tint="@color/white"
            android:alpha="0.5"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Linterna" />
    </LinearLayout>

    <!-- Instrucción inferior -->
    <TextView
        android:id="@+id/tvInstruccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:text="Apunta la cámara al código QR del proyecto"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="@font/lato_family"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/overlay_dark_transparent" />

</FrameLayout>
