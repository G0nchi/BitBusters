<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Reusable text styles -->
    <style name="TextAppearance.BitBusters.DisplayTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">25sp</item>
        <item name="android:lineHeight">40sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.BitBusters.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="TextAppearance.BitBusters.ChipActive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/neutral_soft_1</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="TextAppearance.BitBusters.ChipInactive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/neutral_dark</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <!-- Reusable component styles -->
    <style name="Widget.BitBusters.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/brand_lime</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="Widget.BitBusters.ChipActive" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">55dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">18dp</item>
        <item name="insetLeft">0dp</item>
        <item name="insetRight">0dp</item>
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
        <item name="backgroundTint">@color/brand_deep_blue</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.BitBusters.ChipInactive" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">55dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">18dp</item>
        <item name="insetLeft">0dp</item>
        <item name="insetRight">0dp</item>
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
        <item name="backgroundTint">@color/neutral_soft_1</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
